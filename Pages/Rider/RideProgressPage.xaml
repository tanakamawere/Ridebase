<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Ridebase.ViewModels.Rider"
             x:Class="Ridebase.Pages.Rider.RideProgressPage"
             x:DataType="vm:RideProgressViewModel"
             Title="Ride progress">
    <VerticalStackLayout Padding="16" Spacing="12">
        <Label FontAttributes="Bold" FontSize="20" Text="Ride status" />
        <Label Text="{Binding RideStatusText}" />
        <Label FontAttributes="Bold" Text="Driver phone" />
        <Label Text="{Binding OtherPartyPhoneNumber}" />
        <Button Command="{Binding CancelRideCommand}" Text="Cancel Ride" />
    </VerticalStackLayout>
</ContentPage>