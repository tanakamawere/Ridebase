<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Ridebase.Pages.Rider.RideSelectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:Ridebase.Models.Ride"
    xmlns:vm="clr-namespace:Ridebase.ViewModels.Rider"
    x:DataType="vm:RideSelectionViewModel"
    Shell.NavBarIsVisible="False">

    <Grid BackgroundColor="{StaticResource KaBackground}" RowDefinitions="Auto,*">
        <VerticalStackLayout Padding="20,20,20,12" Spacing="8">
            <Label Style="{StaticResource KaLabelMd}" Text="MATCHING RESULTS" />
            <Label Style="{StaticResource KaHeadlineLabel}" Text="Choose your driver" />
            <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding RideRequest.DestinationAddress}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1" Padding="20,0,20,28" RowDefinitions="*,Auto" RowSpacing="12">
            <CollectionView ItemsSource="{Binding DriversList}">
                <CollectionView.EmptyView>
                    <Border Style="{StaticResource KaSectionSurface}">
                        <VerticalStackLayout Spacing="8">
                            <Label Style="{StaticResource KaTitleLabel}" Text="Waiting for offers" />
                            <Label Style="{StaticResource KaMutedBodyLabel}" Text="Nearby drivers are reviewing your request and may accept or counter your offer." />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:DriverOfferSelectionModel">
                        <Border Margin="0,0,0,12" Style="{StaticResource KaFleetModuleCard}">
                            <VerticalStackLayout Spacing="14">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <Border BackgroundColor="{StaticResource KaSurfaceContainerLow}" HeightRequest="56" StrokeThickness="0" StrokeShape="RoundRectangle 18" WidthRequest="56">
                                        <Label FontFamily="fasolid" FontSize="24" HorizontalOptions="Center" Text="&#xf007;" TextColor="{StaticResource KaPrimary}" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Style="{StaticResource KaTitleLabel}" Text="{Binding Driver.Name}" />
                                        <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding Driver.Vehicle}" />
                                        <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding Driver.Rating, StringFormat='Rating {0:F1}'}" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="2" Style="{StaticResource KaStatusChipActive}">
                                        <Label Style="{StaticResource KaStatusChipLabel}" Text="{Binding OfferTypeLabel}" />
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Style="{StaticResource KaSectionSurface}">
                                        <VerticalStackLayout Spacing="6">
                                            <Label Style="{StaticResource KaLabelMd}" Text="PICKUP ETA" />
                                            <Label Style="{StaticResource KaMetricValue}" Text="{Binding EtaToPickupMinutes, StringFormat='{0} min'}" />
                                            <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding Distance, StringFormat='{0:F1} km away'}" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource KaSectionSurface}">
                                        <VerticalStackLayout Spacing="6">
                                            <Label Style="{StaticResource KaLabelMd}" Text="FARE" />
                                            <Label Style="{StaticResource KaMetricValue}" Text="{Binding OfferAmount, StringFormat='${0:F2}'}" />
                                            <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding FareDelta, StringFormat='Delta ${0:F2}'}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>

                                <VerticalStackLayout Spacing="4">
                                    <Label Style="{StaticResource KaLabelMd}" Text="TRIP" />
                                    <Label Style="{StaticResource KaBodyLabel}" Text="{Binding PickupAddress}" />
                                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding DestinationAddress}" />
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <Button
                                        Grid.Column="0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RideSelectionViewModel}}, Path=DeclineDriverCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource KaSecondaryButton}"
                                        Text="Decline" />
                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RideSelectionViewModel}}, Path=SelectDriverCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource KaPrimaryButton}"
                                        Text="Accept Driver" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button
                Grid.Row="1"
                Command="{Binding CancelRideCommand}"
                Style="{StaticResource KaSecondaryButton}"
                Text="Cancel Search"
                TextColor="{StaticResource KaError}" />
        </Grid>
    </Grid>
</ContentPage>
