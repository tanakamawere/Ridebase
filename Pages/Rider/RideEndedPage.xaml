<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Ridebase.ViewModels.Rider"
    x:Class="Ridebase.Pages.Rider.RideEndedPage"
    x:DataType="vm:RideEndedViewModel"
    Shell.NavBarIsVisible="False">
    <ScrollView BackgroundColor="{StaticResource KaBackground}">
        <VerticalStackLayout Padding="20,28,20,32" Spacing="20">
            <Label Style="{StaticResource KaLabelMd}" Text="TRIP COMPLETE" />
            <Label Style="{StaticResource KaHeadlineLabel}" Text="{Binding DriverName, StringFormat='Rate {0}'}" />
            <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding DestinationText}" />

            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="16">
                    <Label Style="{StaticResource KaTitleLabel}" Text="{Binding FareText, StringFormat='Final fare {0}'}" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="Your feedback helps us tune rider and driver experiences before backend integration goes live." />

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="1" Style="{StaticResource KaSecondaryButton}" Text="1" />
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="2" Style="{StaticResource KaSecondaryButton}" Text="2" />
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="3" Style="{StaticResource KaSecondaryButton}" Text="3" />
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="4" Style="{StaticResource KaSecondaryButton}" Text="4" />
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="5" Style="{StaticResource KaPrimaryButton}" Text="5" />
                    </HorizontalStackLayout>

                    <Editor AutoSize="TextChanges" HeightRequest="120" Placeholder="Share anything helpful about the ride" Text="{Binding Feedback}" />
                    <Button Command="{Binding SubmitRatingCommand}" Style="{StaticResource KaPrimaryButton}" Text="{Binding SelectedRating, StringFormat='Submit {0}-star rating'}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
