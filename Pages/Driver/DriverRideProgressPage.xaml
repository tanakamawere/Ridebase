<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Ridebase.Pages.Driver.DriverRideProgressPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Ridebase.ViewModels.Driver"
    Title="Ride Progress"
    x:DataType="vm:DriverRideProgressViewModel"
    Shell.TabBarIsVisible="False">
    <ScrollView BackgroundColor="{StaticResource KaBackground}">
        <VerticalStackLayout Padding="20,20,20,30" Spacing="18">
            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="10">
                    <Label Style="{StaticResource KaLabelMd}" Text="LIVE TRIP" />
                    <Label Style="{StaticResource KaHeadlineLabel}" Text="{Binding CurrentStatus}" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="Navigation and ETA placeholders are ready for backend and maps integration." />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaSectionSurface}">
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource KaSectionTitle}" Text="Rider" />
                    <Label Style="{StaticResource KaBodyLabel}" Text="{Binding RiderName}" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding RiderPhoneNumber}" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding AcceptedFareText, StringFormat='Accepted fare {0}'}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaSectionSurface}">
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource KaSectionTitle}" Text="Route" />
                    <Label Style="{StaticResource KaBodyLabel}" Text="{Binding PickupAddress}" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding DestinationAddress}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Command="{Binding MarkArrivedCommand}" Style="{StaticResource KaSecondaryButton}" Text="Mark Arrived" />
                <Button Grid.Column="1" Command="{Binding StartTripCommand}" Style="{StaticResource KaPrimaryButton}" Text="Start Journey" />
            </Grid>

            <Button Command="{Binding CompleteTripCommand}" Style="{StaticResource KaPrimaryButton}" Text="End Journey" />
            <Button BackgroundColor="{StaticResource KaError}" Text="SOS" TextColor="{StaticResource KaOnPrimary}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
