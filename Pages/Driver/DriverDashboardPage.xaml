<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Ridebase.Pages.Driver.DriverDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dxc="clr-namespace:DevExpress.Maui.Controls;assembly=DevExpress.Maui.Controls"
    xmlns:icons="clr-namespace:Ridebase.Helpers.FontsCode"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:models="clr-namespace:Ridebase.Models.Ride"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Ridebase.ViewModels.Driver"
    xmlns:wits="http://what.is.this.sheet/schemas/controls"
    Title="Driver Dashboard"
    x:DataType="vm:DriverDashboardViewModel">

    <ContentPage.Content>
        <ScrollView>
            <StackLayout Padding="10">
                <!--  Live Status  -->
                <StackLayout HorizontalOptions="Center" Orientation="Horizontal">
                    <Switch x:Name="LiveStatusSwitch" IsEnabled="{Binding CanGoOnline}" IsToggled="{Binding IsOnline}" />
                    <Label
                        x:Name="LiveStatusLabel"
                        Text="{Binding OnlineStatusText}"
                        VerticalOptions="Center" />
                </StackLayout>

                <Border Margin="0,10" Padding="12" StrokeThickness="1">
                    <StackLayout Spacing="8">
                        <Label FontAttributes="Bold" FontSize="Medium" Text="Driver subscription" />
                        <Label Text="{Binding SubscriptionMessage}" />
                        <Label Text="{Binding SubscriptionDetail}" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding GoToDriverProfileCommand}" Text="Manage billing" />
                            <Button Command="{Binding RefreshSubscriptionStateCommand}" Text="Refresh status" />
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!--  Earnings Summary  -->
                <Border Margin="0,10" Padding="10">
                    <StackLayout>
                        <Label
                            FontAttributes="Bold"
                            FontSize="Medium"
                            Text="Earnings Summary" />
                        <Label Text="Daily Earnings: $XXX.XX" />
                        <Label Text="Weekly Earnings: $XXX.XX" />
                    </StackLayout>
                </Border>

                <!--  Ride Requests  -->
                <Border
                    Margin="0,10"
                    Padding="10"
                    Stroke="#cccccc"
                    StrokeThickness="1">
                    <StackLayout>
                        <Label
                            FontAttributes="Bold"
                            FontSize="Medium"
                            Text="Ride Requests" />
                        <CollectionView EmptyView="There are no current riders near you." ItemsSource="{Binding RideRequests}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:RideRequestModel">
                                    <!--  Example Request  -->
                                    <Border
                                        Margin="0,5"
                                        Padding="10"
                                        Stroke="#cccccc"
                                        StrokeThickness="1">
                                        <StackLayout>
                                            <Label Text="{Binding RiderId, StringFormat='Passenger: {0}'}" />
                                            <Label Text="{Binding OfferAmount, StringFormat='Offer: USD$ {0:F2}'}" />
                                            <Label Text="Pickup: Location available" />
                                            <Label Text="Drop-off: Location available" />
                                            <StackLayout
                                                HorizontalOptions="Center"
                                                Orientation="Horizontal"
                                                Spacing="5">
                                                <Button
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverDashboardViewModel}}, Path=GoToRideInProgressCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Text="Accept" />
                                                <Button Text="Reject" />
                                            </StackLayout>
                                        </StackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <!--  Add more requests as needed  -->
                    </StackLayout>
                </Border>

                <!--  Navigation Shortcuts  -->
                <Border
                    Margin="0,10"
                    Padding="10"
                    Stroke="#cccccc"
                    StrokeThickness="1">
                    <StackLayout Spacing="10">
                        <Label
                            FontAttributes="Bold"
                            FontSize="Medium"
                            Text="Navigation Shortcuts" />
                        <Button Clicked="Button_Clicked" Text="Open Google Maps" />
                    </StackLayout>
                </Border>

                <dxc:BottomSheet x:Name="bottomSheet" State="FullExpanded">
                    <ScrollView>
                        <StackLayout Padding="10" Spacing="10">
                            <!--  Passenger Info  -->
                            <Border Padding="10" StrokeThickness="1">
                                <StackLayout Spacing="5">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="Medium"
                                        Text="Passenger Info" />
                                    <Label Text="Name: Jane Smith" />
                                    <Label Text="Pickup: 789 Pine St" />
                                    <Label Text="Drop-off: 321 Oak Ave" />
                                </StackLayout>
                            </Border>

                            <!--  Trip Details  -->
                            <Border Padding="10" StrokeThickness="1">
                                <StackLayout Spacing="5">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="Medium"
                                        Text="Trip Details" />
                                    <Label Text="Distance: 5.2 miles" />
                                    <Label Text="Estimated Fare: $12.50" />
                                </StackLayout>
                            </Border>

                            <!--  Accept/Decline Buttons  -->
                            <StackLayout
                                HorizontalOptions="Center"
                                Orientation="Horizontal"
                                Spacing="20">
                                <Button
                                    x:Name="AcceptButton"
                                    Command="{Binding GoToRideInProgressCommand}"
                                    Text="Accept" />
                                <Button x:Name="DeclineButton" Text="Decline" />
                            </StackLayout>
                        </StackLayout>
                    </ScrollView>
                </dxc:BottomSheet>
            </StackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>