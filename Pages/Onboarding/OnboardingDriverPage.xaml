<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Ridebase.Pages.Onboarding.OnboardingDriverPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:Ridebase.Converters"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Ridebase.ViewModels.Onboarding"
    Title="{Binding Title}"
    x:DataType="vm:OnboardingDriverViewModel">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ObjectToBooleanConverter x:Key="ObjectToBooleanConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label
                FontAttributes="Bold"
                FontSize="Title"
                HorizontalOptions="Center"
                Text="Driver Setup" />

            <Label
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="Complete your personal, vehicle and license information."
                TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />

            <Border Padding="16" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                <VerticalStackLayout Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="Medium"
                        Text="Profile details from previous step" />
                    <Label Text="Name" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                    <Label FontAttributes="Bold" Text="{Binding FullName}" />
                    <Label Text="Phone number" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                    <Label FontAttributes="Bold" Text="{Binding PhoneNumber}" />
                </VerticalStackLayout>
            </Border>

            <Label Margin="0,8,0,0" Text="Car Make" />
            <Entry
                Placeholder="e.g. Toyota"
                Text="{Binding CarMake}" />

            <Label Text="Car Model" />
            <Entry
                Placeholder="e.g. Corolla"
                Text="{Binding CarModel}" />

            <Label Text="Year" />
            <Entry
                Keyboard="Numeric"
                Placeholder="e.g. 2020"
                Text="{Binding CarYear}" />

            <Label Text="License Plate" />
            <Entry
                Placeholder="e.g. ABC 1234"
                Text="{Binding LicensePlate}" />

            <Label Text="Driver License Number" />
            <Entry
                Placeholder="e.g. DL-2026-00123"
                Text="{Binding DriverLicenseNumber}" />

            <HorizontalStackLayout Spacing="8">
                <Label Text="Available now" VerticalOptions="Center" />
                <Switch IsToggled="{Binding IsAvailable}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="8">
                <Label Text="Subscription is managed after setup" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Border Padding="16" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="Medium"
                        Text="Driver Photo" />
                    <Image
                        Aspect="AspectFill"
                        HeightRequest="180"
                        IsVisible="{Binding DriverPhotoPath, Converter={StaticResource ObjectToBooleanConverter}}"
                        Source="{Binding DriverPhotoPath}" />
                    <Label
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        Text="{Binding DriverPhotoStatus}"
                        TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button
                            Command="{Binding TakeDriverPhotoCommand}"
                            HorizontalOptions="FillAndExpand"
                            Text="Take photo" />
                        <Button
                            Command="{Binding PickDriverPhotoCommand}"
                            HorizontalOptions="FillAndExpand"
                            Text="Choose from gallery" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label
                Margin="0,8,0,0"
                FontAttributes="Bold"
                Text="Driver's License" />

            <Border Padding="16" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        Text="{Binding DriverLicenseStatus}"
                        TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                    <Button
                        Command="{Binding UploadLicenseCommand}"
                        Text="Upload Driver's License" />
                </VerticalStackLayout>
            </Border>

            <Button
                Margin="0,16,0,0"
                Command="{Binding CompleteOnboardingCommand}"
                IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                Text="Complete Setup" />

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
