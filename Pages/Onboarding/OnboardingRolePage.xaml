<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Ridebase.Pages.Onboarding.OnboardingRolePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Ridebase.ViewModels.Onboarding"
    Title="{Binding Title}"
    x:DataType="vm:OnboardingRoleViewModel">

    <ScrollView BackgroundColor="{StaticResource KaBackground}">
        <VerticalStackLayout Padding="20,20,20,32" Spacing="20">
            <Border
                Background="{StaticResource KaPrimaryGradientBrush}"
                Padding="20"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontFamily="{StaticResource KaBodyFontFamily}"
                        FontSize="12"
                        LetterSpacing="2"
                        Text="STEP 2"
                        TextColor="#C7E4E4" />
                    <Label
                        FontFamily="{StaticResource KaDisplayFontFamily}"
                        FontSize="30"
                        FontAttributes="Bold"
                        Text="How will you use Ridebase?"
                        TextColor="{StaticResource KaOnPrimary}" />
                    <Label
                        FontFamily="{StaticResource KaBodyFontFamily}"
                        FontSize="14"
                        Text="Choose the experience that best fits today. You can switch later from your profile."
                        TextColor="#D7ECEB" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="14">
                    <Border
                        BackgroundColor="{StaticResource KaSecondaryContainer}"
                        HeightRequest="52"
                        HorizontalOptions="Start"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        WidthRequest="52">
                        <Label
                            FontFamily="fasolid"
                            FontSize="22"
                            HorizontalOptions="Center"
                            Text="&#xf1b9;"
                            TextColor="{StaticResource KaPrimary}"
                            VerticalOptions="Center" />
                    </Border>
                    <Label Style="{StaticResource KaHeadlineLabel}" Text="Rider" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="Book rides, track drivers live, manage activity, and pay from your wallet." />
                    <Button
                        Command="{Binding ChooseRiderCommand}"
                        IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                        Style="{StaticResource KaPrimaryButton}"
                        Text="Continue as Rider" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="14">
                    <Border
                        BackgroundColor="{StaticResource KaTertiaryContainer}"
                        HeightRequest="52"
                        HorizontalOptions="Start"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        WidthRequest="52">
                        <Label
                            FontFamily="fasolid"
                            FontSize="22"
                            HorizontalOptions="Center"
                            Text="&#xf5e4;"
                            TextColor="{StaticResource KaTertiary}"
                            VerticalOptions="Center" />
                    </Border>
                    <Label Style="{StaticResource KaHeadlineLabel}" Text="Driver" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="Set up your vehicle, manage subscriptions, and earn through the driver workspace." />
                    <Button
                        Command="{Binding ChooseDriverCommand}"
                        IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                        Style="{StaticResource KaSecondaryButton}"
                        Text="Continue as Driver" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator
                Color="{StaticResource KaPrimary}"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
