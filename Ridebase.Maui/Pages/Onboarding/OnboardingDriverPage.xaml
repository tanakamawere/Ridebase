<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Ridebase.Pages.Onboarding.OnboardingDriverPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:Ridebase.Converters"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Ridebase.ViewModels.Onboarding"
    Title="{Binding Title}"
    x:DataType="vm:OnboardingDriverViewModel">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ObjectToBooleanConverter x:Key="ObjectToBooleanConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView BackgroundColor="{StaticResource KaBackground}">
        <VerticalStackLayout Padding="20,20,20,32" Spacing="20">
            <Border
                Background="{StaticResource KaPrimaryGradientBrush}"
                Padding="20"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontFamily="{StaticResource KaBodyFontFamily}"
                        FontSize="12"
                        Text="STEP 3"
                        TextColor="#C7E4E4" />
                    <Label
                        FontFamily="{StaticResource KaDisplayFontFamily}"
                        FontSize="30"
                        FontAttributes="Bold"
                        Text="Driver setup"
                        TextColor="{StaticResource KaOnPrimary}" />
                    <Label
                        FontFamily="{StaticResource KaBodyFontFamily}"
                        FontSize="14"
                        Text="Complete your vehicle and identity details so dispatch can trust every trip."
                        TextColor="#D7ECEB" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaSectionSurface}">
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource KaSectionTitle}" Text="Profile details" />
                    <Label Style="{StaticResource KaLabelMd}" Text="Name" />
                    <Label Style="{StaticResource KaTitleLabel}" Text="{Binding FullName}" />
                    <Label Style="{StaticResource KaLabelMd}" Text="Phone Number" />
                    <Label Style="{StaticResource KaTitleLabel}" Text="{Binding PhoneNumber}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="18">
                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource KaFieldLabel}" Text="Car Make" />
                        <Border Style="{StaticResource KaInputBorder}">
                            <Entry
                                Placeholder="e.g. Toyota"
                                Style="{StaticResource KaEntry}"
                                Text="{Binding CarMake}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource KaFieldLabel}" Text="Car Model" />
                        <Border Style="{StaticResource KaInputBorder}">
                            <Entry
                                Placeholder="e.g. Corolla"
                                Style="{StaticResource KaEntry}"
                                Text="{Binding CarModel}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource KaFieldLabel}" Text="Year" />
                        <Border Style="{StaticResource KaInputBorder}">
                            <Entry
                                Keyboard="Numeric"
                                Placeholder="e.g. 2020"
                                Style="{StaticResource KaEntry}"
                                Text="{Binding CarYear}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource KaFieldLabel}" Text="License Plate" />
                        <Border Style="{StaticResource KaInputBorder}">
                            <Entry
                                Placeholder="e.g. ABC 1234"
                                Style="{StaticResource KaEntry}"
                                Text="{Binding LicensePlate}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource KaFieldLabel}" Text="Driver License Number" />
                        <Border Style="{StaticResource KaInputBorder}">
                            <Entry
                                Placeholder="e.g. DL-2026-00123"
                                Style="{StaticResource KaEntry}"
                                Text="{Binding DriverLicenseNumber}" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaSectionSurface}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Style="{StaticResource KaTitleLabel}" Text="Available now" />
                        <Label Style="{StaticResource KaMutedBodyLabel}" Text="Turn this on if you want to start receiving work as soon as setup is complete." />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1" IsToggled="{Binding IsAvailable}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource KaSectionTitle}" Text="Driver Photo" />
                    <Image
                        Aspect="AspectFill"
                        HeightRequest="190"
                        IsVisible="{Binding DriverPhotoPath, Converter={StaticResource ObjectToBooleanConverter}}"
                        Source="{Binding DriverPhotoPath}" />
                    <Label
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource KaMutedBodyLabel}"
                        Text="{Binding DriverPhotoStatus}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button
                            Command="{Binding TakeDriverPhotoCommand}"
                            Grid.Column="0"
                            Style="{StaticResource KaSecondaryButton}"
                            Text="Take Photo" />
                        <Button
                            Command="{Binding PickDriverPhotoCommand}"
                            Grid.Column="1"
                            Style="{StaticResource KaPrimaryButton}"
                            Text="Choose from Gallery" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource KaSectionTitle}" Text="Driver's License" />
                    <Label
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource KaMutedBodyLabel}"
                        Text="{Binding DriverLicenseStatus}" />
                    <Button
                        Command="{Binding UploadLicenseCommand}"
                        Style="{StaticResource KaSecondaryButton}"
                        Text="Upload Driver's License" />
                </VerticalStackLayout>
            </Border>

            <Button
                Command="{Binding CompleteOnboardingCommand}"
                IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                Style="{StaticResource KaPrimaryButton}"
                Text="Complete Setup" />

            <ActivityIndicator
                Color="{StaticResource KaPrimary}"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
