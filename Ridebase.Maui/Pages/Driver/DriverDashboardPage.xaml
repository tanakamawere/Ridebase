<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Ridebase.Pages.Driver.DriverDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:icons="clr-namespace:Ridebase.Helpers.FontsCode"
    xmlns:driverModels="clr-namespace:Ridebase.Models.Driver"
    xmlns:rideModels="clr-namespace:Ridebase.Models.Ride"
    xmlns:vm="clr-namespace:Ridebase.ViewModels.Driver"
    Title="Driver Dashboard"
    x:DataType="vm:DriverDashboardViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,36" Spacing="20">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Border BackgroundColor="{StaticResource KaSecondaryContainer}" HeightRequest="48" StrokeThickness="0" StrokeShape="RoundRectangle 24" VerticalOptions="Center" WidthRequest="48">
                    <Label FontFamily="fasolid" FontSize="20" HorizontalOptions="Center" Text="{x:Static icons:Fasolid.User}" TextColor="{StaticResource KaPrimary}" VerticalOptions="Center" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Style="{StaticResource KaTitleLabel}" Text="{Binding DriverDisplayName}" />
                    <HorizontalStackLayout Spacing="8">
                        <Switch IsEnabled="{Binding CanGoOnline}" IsToggled="{Binding IsOnline}" Scale="0.8" />
                        <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding OnlineStatusText}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <Border Grid.Column="2" BackgroundColor="{StaticResource KaPrimary}" Padding="14,7" StrokeThickness="0" StrokeShape="RoundRectangle 9999" VerticalOptions="Start">
                    <Label FontFamily="{StaticResource KaBodyFontFamily}" FontSize="11" FontAttributes="Bold" Text="{Binding OnlineBadgeText}" TextColor="{StaticResource KaOnPrimary}" />
                </Border>
            </Grid>

            <Border Background="{StaticResource KaPrimaryGradientBrush}" Padding="20" StrokeThickness="0" StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Spacing="14">
                    <Label FontFamily="{StaticResource KaBodyFontFamily}" FontSize="12" CharacterSpacing="2" Text="{Binding CurrentPlanCaption}" TextColor="#A8D2D2" />
                    <Label FontFamily="{StaticResource KaDisplayFontFamily}" FontSize="28" FontAttributes="Bold" LineBreakMode="WordWrap" Text="{Binding CurrentPlanTitle}" TextColor="{StaticResource KaOnPrimary}" />
                    <Label FontFamily="{StaticResource KaBodyFontFamily}" FontSize="13" Text="{Binding SubscriptionDetail}" TextColor="#D7ECEB" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Command="{Binding RefreshSubscriptionStateCommand}" Style="{StaticResource KaSecondaryButton}" Text="Refresh Status" />
                        <Button Grid.Column="1" Command="{Binding GoToDriverProfileCommand}" Style="{StaticResource KaTertiaryButton}" Text="{Binding RenewActionText}" TextColor="{StaticResource KaOnPrimary}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Style="{StaticResource KaLabelMd}" Text="DAILY GOAL" />
                            <HorizontalStackLayout Spacing="6">
                                <Label Style="{StaticResource KaDisplayLabel}" Text="{Binding DailyGoalAmount, StringFormat='${0:0}'}" />
                                <Label Margin="0,10,0,0" Style="{StaticResource KaMutedBodyLabel}" Text="{Binding DailyGoalTarget, StringFormat='/{0:0}'}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <Label Grid.Column="1" FontFamily="fasolid" FontSize="16" Text="{x:Static icons:Fasolid.Flag}" TextColor="{StaticResource KaPrimary}" />
                    </Grid>

                    <ProgressBar HeightRequest="8" Progress="{Binding DailyGoalProgress}" ProgressColor="{StaticResource KaPrimary}" BackgroundColor="{StaticResource KaSurfaceContainer}" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding DailyGoalSupportText}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Style="{StaticResource KaSectionTitle}" Text="Incoming Ride Requests" />
                        <Button Grid.Column="1" Command="{Binding RefreshSubscriptionStateCommand}" Style="{StaticResource KaTertiaryButton}" Text="Refresh" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding RideRequests}">
                        <CollectionView.EmptyView>
                            <Border Style="{StaticResource KaSectionSurface}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Style="{StaticResource KaTitleLabel}" Text="No requests nearby" />
                                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="Stay online and we will surface new trip opportunities here." />
                                </VerticalStackLayout>
                            </Border>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="rideModels:RideRequestModel">
                                <Border Margin="0,0,0,12" Style="{StaticResource KaSectionSurface}">
                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Style="{StaticResource KaTitleLabel}" Text="{Binding RiderName}" />
                                                <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding OfferAmount, StringFormat='Rider offer • ${0:F2}'}" />
                                            </VerticalStackLayout>
                                            <Border Style="{StaticResource KaStatusChipActive}">
                                                <Label Style="{StaticResource KaStatusChipLabel}" Text="NEARBY" />
                                            </Border>
                                        </Grid>

                                        <VerticalStackLayout Spacing="4">
                                            <Label Style="{StaticResource KaBodyLabel}" Text="{Binding StartAddress}" />
                                            <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding DestinationAddress}" />
                                            <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding RecommendedAmount, StringFormat='Recommended fare • ${0:F2}'}" />
                                            <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding EstimatedDistanceKm, StringFormat='Distance to pickup • {0:F1} km'}" />
                                        </VerticalStackLayout>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <Button
                                                Grid.Column="0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverDashboardViewModel}}, Path=CounterOfferCommand}"
                                                CommandParameter="{Binding .}"
                                                Style="{StaticResource KaSecondaryButton}"
                                                Text="Counter Offer" />
                                            <Button
                                                Grid.Column="1"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverDashboardViewModel}}, Path=GoToRideInProgressCommand}"
                                                CommandParameter="{Binding .}"
                                                Style="{StaticResource KaPrimaryButton}"
                                                Text="Accept Request" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Style="{StaticResource KaLabelMd}" Text="LAST TRIP" />
                            <Label Style="{StaticResource KaTitleLabel}" Text="{Binding LastTripTitle}" />
                            <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding LastTripTimeText}" />
                        </VerticalStackLayout>
                        <Border Style="{StaticResource KaStatusChip}">
                            <Label Style="{StaticResource KaStatusChipLabel}" Text="TRACKED" />
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border BackgroundColor="{StaticResource KaSurfaceContainerLow}" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 12" WidthRequest="44">
                            <Label FontFamily="fasolid" FontSize="18" HorizontalOptions="Center" Text="{x:Static icons:Fasolid.TruckFront}" TextColor="{StaticResource KaPrimary}" VerticalOptions="Center" />
                        </Border>

                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Style="{StaticResource KaMutedBodyLabel}" Text="Earnings" />
                                <Label Style="{StaticResource KaMetricValue}" Text="{Binding LastTripEarningsText}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Command="{Binding OpenGoogleMapsCommand}" Style="{StaticResource KaSecondaryButton}" Text="Open Maps" VerticalOptions="End" />
                        </Grid>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource KaSectionSurface}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Border BackgroundColor="{StaticResource KaSurfaceContainerLowest}" HeightRequest="48" StrokeThickness="0" StrokeShape="RoundRectangle 24" WidthRequest="48">
                        <Label FontFamily="fasolid" FontSize="20" HorizontalOptions="Center" Text="{x:Static icons:Fasolid.Gear}" TextColor="{StaticResource KaPrimary}" VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Style="{StaticResource KaTitleLabel}" Text="{Binding VehicleHeadline}" />
                        <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding VehicleDiagnostics}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="2" Command="{Binding GoToDriverProfileCommand}" Style="{StaticResource KaTertiaryButton}" Text="Manage" />
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,Auto">
                <Label Style="{StaticResource KaSectionTitle}" Text="Recent Insights" />
                <Button Grid.Column="1" Command="{Binding GoToDriverProfileCommand}" Style="{StaticResource KaTertiaryButton}" Text="View All" />
            </Grid>

            <CollectionView ItemsSource="{Binding RecentInsights}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="driverModels:DriverInsightModel">
                        <Border Margin="0,0,0,12" Style="{StaticResource KaFleetModuleCard}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                <Border BackgroundColor="{Binding AccentColor}" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 22" VerticalOptions="Center" WidthRequest="44">
                                    <Label FontFamily="fasolid" FontSize="16" HorizontalOptions="Center" Text="{Binding IconGlyph}" TextColor="{StaticResource KaOnSurface}" VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Style="{StaticResource KaTitleLabel}" Text="{Binding Title}" />
                                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding Detail}" />
                                </VerticalStackLayout>

                                <Label Grid.Column="2" Style="{StaticResource KaLabelMd}" Text="{Binding AgeText}" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
