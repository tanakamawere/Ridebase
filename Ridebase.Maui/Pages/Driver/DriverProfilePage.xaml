<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Ridebase.Pages.Driver.DriverProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:icons="clr-namespace:Ridebase.Helpers.FontsCode"
    xmlns:models="clr-namespace:Ridebase.Models.Driver"
    xmlns:vm="clr-namespace:Ridebase.ViewModels.Driver"
    Title="Profile Management"
    x:DataType="vm:DriverProfileViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,36" Spacing="20">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Border BackgroundColor="{StaticResource KaSecondaryContainer}" HeightRequest="52" StrokeThickness="0" StrokeShape="RoundRectangle 16" WidthRequest="52">
                    <Label FontFamily="fasolid" FontSize="22" HorizontalOptions="Center" Text="{x:Static icons:Fasolid.UserTie}" TextColor="{StaticResource KaPrimary}" VerticalOptions="Center" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Style="{StaticResource KaTitleLabel}" Text="{Binding DriverName}" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding MemberSinceText}" />
                </VerticalStackLayout>

                <Border Grid.Column="2" BackgroundColor="{StaticResource KaPrimaryFixed}" Padding="12,6" StrokeThickness="0" StrokeShape="RoundRectangle 9999">
                    <Label Style="{StaticResource KaStatusChipLabel}" Text="ONLINE READY" />
                </Border>
            </Grid>

            <Border Style="{StaticResource KaFleetModuleCard}">
                <VerticalStackLayout Spacing="10">
                    <Label Style="{StaticResource KaLabelMd}" Text="ACTIVE VEHICLE" />
                    <Label Style="{StaticResource KaHeadlineLabel}" Text="{Binding ActiveVehicleName}" />
                    <Label Style="{StaticResource KaTitleLabel}" Text="{Binding ActiveVehiclePlate}" />

                    <HorizontalStackLayout Spacing="8">
                        <Border Style="{StaticResource KaStatusChip}">
                            <Label Style="{StaticResource KaStatusChipLabel}" Text="4.9 Rating" />
                        </Border>
                        <Border Style="{StaticResource KaStatusChip}">
                            <Label Style="{StaticResource KaStatusChipLabel}" Text="1,240 Trips" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding ProfileShortcuts}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:DriverShortcutModel">
                        <Border Margin="0,0,0,12" Style="{StaticResource KaFleetModuleCard}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                <Border BackgroundColor="{Binding AccentColor}" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 14" VerticalOptions="Center" WidthRequest="44">
                                    <Label FontFamily="fasolid" FontSize="16" HorizontalOptions="Center" Text="{Binding IconGlyph}" TextColor="{StaticResource KaOnSurface}" VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Style="{StaticResource KaTitleLabel}" Text="{Binding Title}" />
                                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding Subtitle}" />
                                </VerticalStackLayout>

                                <Label Grid.Column="2" FontFamily="fasolid" FontSize="16" Text="{x:Static icons:Fasolid.ArrowRight}" TextColor="{StaticResource KaOnSurfaceMuted}" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border Style="{StaticResource KaSectionSurface}">
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource KaSectionTitle}" Text="Subscription Management" />
                    <Label Style="{StaticResource KaTitleLabel}" Text="{Binding SubscriptionStatusText}" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding SubscriptionPeriodText}" />
                    <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding SubscriptionIdText}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Command="{Binding StartCheckoutCommand}" Style="{StaticResource KaPrimaryButton}" Text="Subscribe Now" />
                        <Button Grid.Column="1" Command="{Binding OpenBillingPortalCommand}" Style="{StaticResource KaSecondaryButton}" Text="Billing Portal" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Command="{Binding RefreshSubscriptionCommand}" Style="{StaticResource KaTertiaryButton}" Text="Refresh Status" />
                        <Button Grid.Column="1" Command="{Binding CancelSubscriptionCommand}" Style="{StaticResource KaTertiaryButton}" Text="Cancel Plan" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Command="{Binding GoToRiderPagesCommand}" Style="{StaticResource KaSecondaryButton}" Text="Rider Side" />
                <Button Grid.Column="1" Command="{Binding OpenBillingPortalCommand}" Style="{StaticResource KaPrimaryButton}" Text="Manage Billing" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
