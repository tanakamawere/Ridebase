<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Ridebase.Pages.Auth.EmailVerificationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:icons="clr-namespace:Ridebase.Helpers.FontsCode"
    xmlns:vm="clr-namespace:Ridebase.ViewModels"
    x:DataType="vm:EmailVerificationViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter
                xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <VerticalStackLayout
        Padding="24"
        Spacing="20"
        VerticalOptions="Center">

        <!-- Email icon -->
        <Border
            Padding="20"
            BackgroundColor="{StaticResource Primary}"
            HeightRequest="90"
            HorizontalOptions="Center"
            StrokeShape="RoundRectangle 45"
            StrokeThickness="0"
            WidthRequest="90">
            <Image>
                <Image.Source>
                    <FontImageSource
                        FontFamily="fasolid"
                        Glyph="{x:Static icons:Fasolid.Envelope}"
                        Size="40"
                        Color="White" />
                </Image.Source>
            </Image>
        </Border>

        <Label
            FontAttributes="Bold"
            FontSize="22"
            HorizontalOptions="Center"
            Text="Verify Your Email"
            TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

        <Label
            FontSize="14"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            Text="{Binding StatusMessage}"
            TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />

        <!-- OTP code input -->
        <VerticalStackLayout
            Spacing="6"
            IsVisible="{Binding IsVerified, Converter={StaticResource InvertedBoolConverter}}">
            <Label
                FontSize="13"
                Text="Verification Code"
                TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
            <Border
                Padding="14,0"
                BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="0">
                <Entry
                    FontSize="24"
                    HorizontalTextAlignment="Center"
                    Keyboard="Numeric"
                    MaxLength="6"
                    Placeholder="000000"
                    Text="{Binding OtpCode}"
                    TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />
            </Border>
        </VerticalStackLayout>

        <!-- Verify button -->
        <Button
            BackgroundColor="{StaticResource Primary}"
            Command="{Binding VerifyOtpCommand}"
            CornerRadius="24"
            FontAttributes="Bold"
            FontSize="16"
            HeightRequest="52"
            IsVisible="{Binding IsVerified, Converter={StaticResource InvertedBoolConverter}}"
            Text="Verify"
            TextColor="White" />

        <!-- Busy indicator (during verification / auto-login) -->
        <HorizontalStackLayout
            HorizontalOptions="Center"
            IsVisible="{Binding IsBusy}"
            Spacing="8">
            <ActivityIndicator
                HeightRequest="20"
                IsRunning="True"
                WidthRequest="20"
                Color="{StaticResource Primary}" />
            <Label
                FontSize="13"
                Text="{Binding BusyMessage}"
                TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Resend button -->
        <Button
            BackgroundColor="Transparent"
            BorderColor="{StaticResource Primary}"
            BorderWidth="1"
            Command="{Binding ResendEmailCommand}"
            CornerRadius="24"
            FontAttributes="Bold"
            FontSize="14"
            HeightRequest="44"
            IsEnabled="{Binding IsResending, Converter={StaticResource InvertedBoolConverter}}"
            IsVisible="{Binding IsVerified, Converter={StaticResource InvertedBoolConverter}}"
            Text="Resend Code"
            TextColor="{StaticResource Primary}" />

        <!-- Back to login -->
        <Label
            Margin="0,12,0,0"
            FontSize="14"
            HorizontalOptions="Center"
            Text="Back to Sign In"
            TextColor="{StaticResource Primary}">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
            </Label.GestureRecognizers>
        </Label>

    </VerticalStackLayout>

</ContentPage>
