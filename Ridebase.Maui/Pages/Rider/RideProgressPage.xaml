<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Ridebase.ViewModels.Rider"
    x:Class="Ridebase.Pages.Rider.RideProgressPage"
    x:DataType="vm:RideProgressViewModel"
    Title="Ride progress"
    Shell.NavBarIsVisible="False">

    <Grid BackgroundColor="{StaticResource KaBackground}" RowDefinitions="Auto,*">
        <Grid Padding="20,18,20,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
            <Button Grid.Column="0" BackgroundColor="Transparent" Command="{Binding CancelRideCommand}" Text="←" TextColor="{StaticResource KaPrimary}" />
            <VerticalStackLayout Grid.Column="1" Spacing="2">
                <Label Style="{StaticResource KaLabelMd}" Text="ACTIVE TRIP" />
                <Label Style="{StaticResource KaHeadlineLabel}" Text="{Binding EtaHeadline}" />
            </VerticalStackLayout>
            <Border Grid.Column="2" Style="{StaticResource KaStatusChipActive}" VerticalOptions="Center">
                <Label Style="{StaticResource KaStatusChipLabel}" Text="{Binding RideStatusText}" />
            </Border>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,12,20,32" Spacing="20">
                <Border Style="{StaticResource KaFleetModuleCard}">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Style="{StaticResource KaTitleLabel}" Text="{Binding DriverName}" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Style="{StaticResource KaMetricValue}" HorizontalTextAlignment="End" Text="{Binding EstimatedArrivalText}" />
                                <Label Style="{StaticResource KaLabelMd}" HorizontalTextAlignment="End" Text="ETA" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label Style="{StaticResource KaMutedBodyLabel}" Text="{Binding VehicleInfo}" />
                        <Label Style="{StaticResource KaBodyLabel}" Text="{Binding StatusDetail}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Grid.Column="0" Style="{StaticResource KaSectionSurface}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Style="{StaticResource KaLabelMd}" Text="PICKUP" />
                                    <Label Style="{StaticResource KaBodyLabel}" Text="{Binding PickupText}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource KaSectionSurface}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Style="{StaticResource KaLabelMd}" Text="DESTINATION" />
                                    <Label Style="{StaticResource KaBodyLabel}" Text="{Binding DestinationText}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Grid.Column="0" Style="{StaticResource KaSectionSurface}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Style="{StaticResource KaLabelMd}" Text="FARE" />
                                    <Label Style="{StaticResource KaMetricValue}" Text="{Binding EstimatedFareText}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource KaSectionSurface}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Style="{StaticResource KaLabelMd}" Text="DRIVER CONTACT" />
                                    <Label Style="{StaticResource KaBodyLabel}" Text="{Binding OtherPartyPhoneNumber}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border IsVisible="{Binding IsDriverTrackingVisible}" Style="{StaticResource KaSectionSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource KaSectionTitle}" Text="Pickup Tracking" />
                        <Label Style="{StaticResource KaMutedBodyLabel}" Text="Driver is on the way to your pickup point. Live location plumbing is ready for backend integration." />
                    </VerticalStackLayout>
                </Border>

                <Border IsVisible="{Binding IsJourneySummaryVisible}" Style="{StaticResource KaSectionSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource KaSectionTitle}" Text="Ride In Progress" />
                        <Label Style="{StaticResource KaMutedBodyLabel}" Text="ETA, safety controls, and journey updates stay available here while the trip is active." />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource KaSectionSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource KaSectionTitle}" Text="Safety Center" />
                        <Label Style="{StaticResource KaMutedBodyLabel}" Text="Use emergency support, trusted contacts, and ride details when needed." />
                        <Button BackgroundColor="{StaticResource KaError}" Command="{Binding OpenCompletionCommand}" IsEnabled="{Binding CanRateTrip}" Text="{Binding TripActionText}" TextColor="{StaticResource KaOnPrimary}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
